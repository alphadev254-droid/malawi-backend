		{
			"name": "Admin Endpoints",
			"item": [
				{
					"name": "Populate Area Names (Bulk)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/v1/e-reports/admin/populate-area-names",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "e-reports", "admin", "populate-area-names"]
						},
						"description": "Bulk populate display names for all areas that don't have them yet using reverse geocoding"
					}
				},
				{
					"name": "Update Area Name (Manual)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"areaId\": \"your-area-id-here\",\n  \"displayName\": \"New Area Name\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/e-reports/admin/update-area-name",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "e-reports", "admin", "update-area-name"]
						},
						"description": "Manually update the display name for a specific area"
					}
				},
