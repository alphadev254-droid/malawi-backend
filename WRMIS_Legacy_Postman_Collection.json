		{
			"name": "Error Testing",
			"item": [
				{
					"name": "Missing Auth Token",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/wrmis/legacy/approved-permits",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "wrmis", "legacy", "approved-permits"]
						},
						"description": "Should return 401 Unauthorized - no token provided."
					}
				},
				{
					"name": "Invalid Token",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer invalid.token.here" }
						],
						"url": {
							"raw": "{{baseUrl}}/v1/wrmis/legacy/approved-permits",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "wrmis", "legacy", "approved-permits"]
						},
						"description": "Should return 401 Unauthorized - invalid token."
					}
				},
				{
					"name": "License Number Not Found",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwtToken}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/v1/wrmis/legacy/approved-permits/by-license-number?licenseNumber=DOES-NOT-EXIST",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "wrmis", "legacy", "approved-permits", "by-license-number"],
							"query": [
								{ "key": "licenseNumber", "value": "DOES-NOT-EXIST" }
							]
						},
						"description": "Should return 404 Not Found."
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080/api/nwra-apis/ewaterpermit-ws",
			"description": "Base URL including context path"
		},
		{
			"key": "jwtToken",
			"value": "",
			"description": "Auto-populated after running Get JWT Token request"
		},
		{
			"key": "wrmisUsername",
			"value": "wrmis_user",
			"description": "WRMIS auth username"
		},
		{
			"key": "wrmisPassword",
			"value": "wrmis_password",
			"description": "WRMIS auth password"
		}
	]
